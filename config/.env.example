# Misskey API設定
MISSKEY_HTTP_HOST=misskey.vip
MISSKEY_WS_HOST=misskey.vip
MISSKEY_TOKEN=your_token_here

# LLM API設定 (OpenAI互換 - Ollama, LM Studio等で動作)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=http://localhost:11434/v1
# 使用するモデル (Ollama例: gemma3:1b, llama3, qwen2.5)
LLM_MODEL=gemma3:1b

# ロギング設定
# ログ表示範囲 (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
# ノートテキスト表示最大文字数
MAX_NOTE_TEXT_LENGTH=50

# リアクション設定
# リアクションの発火確率 (0.0-1.0)
REACTION_PROBABILITY=1.0
# リプライやリノートにもリアクションするかどうか (true/false)
REACT_TO_REPLIES=false
# フォロワー向け投稿にもリアクションするかどうか (true/false)
REACT_TO_FOLLOWERS=false

# 再試行設定
# API呼び出しの最大再試行回数
MAX_RETRIES=3
# 再試行間の待機時間（秒）
RETRY_DELAY=2

# WebSocket再接続設定
# 初期再接続待機時間（秒）
WS_RECONNECT_DELAY_INITIAL=5
# 最大再接続待機時間（秒）
WS_RECONNECT_DELAY_MAX=60
# 再接続待機時間の増加係数
WS_RECONNECT_FACTOR=1.5

# User-Agent設定
HTTP_USER_AGENT=MisskeyReactionBot/1.0
WS_USER_AGENT=MisskeyReactionBot/1.0

# API設定
API_SECURE=true
WS_SECURE=true